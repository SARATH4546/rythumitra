# Dependencies
node_modules/

# NeDB database files (auto-generated on first run)
server/db/*.db
server/db/*.db~

# Environment files
.env
.env.local
.env.production

# Build output
client/dist/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# ─── Large binary files — DO NOT commit these ────────────────────────────────
# ML Datasets (download via: python server/python/download_datasets.py)
datasets/
!datasets/.gitkeep

# ML Model weights (generated by training — download separately)
server/python/models/*.pth
server/python/models/*.h5
server/python/models/*.pt
server/python/models/v2_*
server/python/models/finetune_*

# Python virtual environment for GPU training
train_venv/

# Test images (large binary dataset samples)
test_data/

# Generated audio files
server/audio/
voice/dynamic/
voice/test_tts.mp3
voice/*.wav
voice/*.ogg

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Kaggle credentials
.kaggle/

# Temporary / scratch files
*.tmp
*.bak
